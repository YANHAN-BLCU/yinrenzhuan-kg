<http://example.org/inkperson/evidence/何主臣_hao> a ex:Evidence ;
    ex:confidence "0.95"^^xsd:float ;
    ex:extractedBy <http://example.org/inkperson/person/何主臣> ;
    ex:extractionMethod "known" ;
    ex:sourceText "何主臣震，一字長卿，亦稱雪漁" .

<http://example.org/inkperson/evidence/何主臣_nativePlace> a ex:Evidence ;
    ex:confidence "0.95"^^xsd:float ;
