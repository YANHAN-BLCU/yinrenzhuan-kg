@prefix ex: <http://example.org/inkperson/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Place a owl:Class ;
    rdfs:subClassOf ex:Thing .

ex:RDF owl:Ontology ex:ontology .

ex:Style a owl:Class ;
    rdfs:subClassOf ex:Thing .

ex:TimePeriod a owl:Class ;
    rdfs:subClassOf ex:Thing .

ex:Work a owl:Class ;
    rdfs:subClassOf ex:Thing .

ex:appellation a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:string .

ex:belongsToSchool a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:SealEngravingSchool .

ex:biography a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:string .

ex:birthYear a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:integer .

ex:birthYearString a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:string .

ex:brotherOf a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:HistoricPerson .

ex:cbdbId a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:Thing .

ex:cbdbReference a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:Thing .

ex:confidence a owl:DatatypeProperty ;
    rdfs:domain ex:Evidence ;
    rdfs:range xsd:float .

ex:createdWork a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:SealWork .

ex:creationPeriod a owl:DatatypeProperty ;
    rdfs:domain ex:SealWork ;
    rdfs:range xsd:string .

ex:ctextId a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:Thing .

ex:ctextReference a owl:ObjectProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range ex:Thing .

ex:dataSource a owl:DatatypeProperty ;
    rdfs:domain ex:Thing ;
    rdfs:range xsd:string .

ex:deathYear a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:integer .

ex:deathYearString a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:string .

ex:description a owl:DatatypeProperty ;
    rdfs:domain ex:SealEngravingSchool ;
    rdfs:range xsd:string .

ex:dynasty a owl:DatatypeProperty ;
    rdfs:domain ex:HistoricPerson ;
    rdfs:range xsd:string .

ex:endYear a owl:DatatypeProperty ;
    rdfs:domain ex:Era ;
    rdfs:range xsd:integer .

