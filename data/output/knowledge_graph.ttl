ex:extractedBy a owl:ObjectProperty ;
    rdfs:domain ex:Evidence ;
    rdfs:range ex:Person .

ex:extractionMethod a owl:DatatypeProperty ;
    rdfs:domain ex:Evidence ;
    rdfs:range xsd:string .

ex:fatherOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:sonOf .

ex:foundedSchool a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:School .

ex:friendOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:fromPlace a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Place .

ex:hao a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:hasPeriod a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:TimePeriod .

ex:hasStyle a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Style .

ex:influencedBy a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:inheritedFrom a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:nativePlace a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:occupation a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:officialRank a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:period a owl:DatatypeProperty ;
    rdfs:domain ex:School ;
    rdfs:range xsd:string .

ex:periodName a owl:DatatypeProperty ;
    rdfs:domain ex:TimePeriod ;
    rdfs:range xsd:string .

ex:personName a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:placeName a owl:DatatypeProperty ;
    rdfs:domain ex:Place ;
    rdfs:range xsd:string .

ex:region a owl:DatatypeProperty ;
    rdfs:domain ex:School ;
    rdfs:range xsd:string .

ex:sameAs a owl:ObjectProperty ;
    rdfs:domain ex:Thing ;
    rdfs:range ex:Thing .

ex:schoolName a owl:DatatypeProperty ;
    rdfs:domain ex:School ;
    rdfs:range xsd:string .

ex:source a owl:ObjectProperty ;
    rdfs:domain ex:Evidence ;
    rdfs:range ex:Thing .

ex:sourceText a owl:DatatypeProperty ;
    rdfs:domain ex:Evidence ;
    rdfs:range xsd:string .

ex:styleName a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:teacherOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:studentOf .

ex:Style a owl:Class ;
    rdfs:subClassOf ex:Thing .

