<http://example.org/inkperson/evidence/何主臣_studentOf> a ex:Evidence ;
    ex:confidence "0.93"^^xsd:float ;
    ex:extractedBy <http://example.org/inkperson/person/何主臣> ;
    ex:extractionMethod "known",
        "ner-scoped" ;
    ex:source "卷二" ;
    ex:sourceText "主臣之於文國博，蓋在師友間",
        "程孟長原，一字六水，新安人。自何主臣繼文國博起，而印章一道遂歸黃山。" .

<http://example.org/inkperson/evidence/何主臣_styleName> a ex:Evidence ;
    ex:confidence "0.95"^^xsd:float,
        "0.99"^^xsd:float ;
    ex:extractedBy <http://example.org/inkperson/person/何主臣> ;
    ex:extractionMethod "known",
        "ner-scoped" ;
    ex:source "卷一" ;
    ex:sourceText "何主臣震，一字長卿，亦稱雪漁",
        "何主臣震，一字長卿，亦稱雪漁，新安之婺源" .

<http://example.org/inkperson/evidence/何主臣_teacherOf> a ex:Evidence ;
    ex:confidence "0.88"^^xsd:float,
        "0.9"^^xsd:float ;
    ex:extractedBy <http://example.org/inkperson/person/何主臣> ;
    ex:extractionMethod "known" ;
    ex:sourceText "凍石之名，始見於世，豔傳四方",
        "千秋繼何主臣起，故為印一以何氏為宗" .

