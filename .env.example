# =====================================================================
# 印人传知识图谱系统 - 环境变量配置模板
# =====================================================================
# 复制本文件为 `.env` 并填入你自己的 API Key：
#   cp .env.example .env
# 然后编辑 .env，把占位符 `your_xxx_key_here` 替换为真实值。
#
# 注意：`.env` 已被 .gitignore 排除，不会被提交到 Git。
# =====================================================================


# ---------- LLM 主体（用于问句规范化 / 答案合成） ----------
# 兼容 OpenAI 协议的服务均可（DeepSeek / 通义千问 / 智谱 / OpenAI 等）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat


# ---------- Embedding（用于 RAG 原文检索） ----------
# 默认使用 SiliconFlow 的 BAAI/bge-m3；可改为其他 OpenAI 兼容服务
# 若不填则复用 OPENAI_API_KEY
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3


# ---------- 本地 Ollama（可选，用于 SPARQL LLM 生成） ----------
# 如不需要 LLM 生成 SPARQL，可保持默认（程序会跳过）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
